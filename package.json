{
  "name": "@summit-electric-supply/ember-validators",
  "version": "2.1.13",
  "description": "A collection of Ember validators",
  "keywords": [
    "ember-addon",
    "validations",
    "validators"
  ],
  "homepage": "https://github.com/summit-electric-supply/ember-validators",
  "repository": "https://github.com/summit-electric-supply/ember-validators",
  "license": "MIT",
  "contributors": [
    "Offir Golan <offirgolan@gmail.com> (https://github.com/offirgolan)",
    "Steve Jabour <steve@jabour.me> (https://github.com/atsjj)"
  ],
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "build:test": "ember build --environment=test",
    "lint": "npm-run-all --aggregate-output --continue-on-error --parallel lint:*",
    "lint:dependency": "ember dependency-lint",
    "lint:hbs": "ember-template-lint .",
    "lint:js": "eslint .",
    "start": "ember serve",
    "test": "npm-run-all lint:* test:*",
    "test:ember": "ember exam --query=nolint --split=2 --parallel=1",
    "test:ember-compatibility": "ember try:each",
    "ci:ember-compatibility": "ember try:one",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "broccoli-funnel": "^3.0.8",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-typescript": "^5.3.0",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@ember/optional-features": "^3.0.0",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/test-setup": "^4.0.0",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@types/ember__application": "^4.0.11",
    "@types/ember__array": "^4.0.10",
    "@types/ember__component": "^4.0.22",
    "@types/ember__controller": "^4.0.12",
    "@types/ember__debug": "^4.0.8",
    "@types/ember__engine": "^4.0.11",
    "@types/ember__error": "^4.0.6",
    "@types/ember__object": "^4.0.12",
    "@types/ember__polyfills": "^4.0.6",
    "@types/ember__routing": "^4.0.23",
    "@types/ember__runloop": "^4.0.10",
    "@types/ember__service": "^4.0.9",
    "@types/ember__string": "^3.0.15",
    "@types/ember__template": "^4.0.7",
    "@types/ember__test": "^4.0.6",
    "@types/ember__test-helpers": "^2.9.3",
    "@types/ember__utils": "^4.0.7",
    "@types/ember-qunit": "^6.1.3",
    "@types/ember-resolver": "^9.0.2",
    "@types/htmlbars-inline-precompile": "^3.0.4",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "babel-eslint": "^10.1.0",
    "broccoli-asset-rev": "^3.0.0",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~6.12.0",
    "ember-cli-code-coverage": "^3.1.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-dependency-lint": "^2.0.1",
    "ember-cli-github-pages": "^0.2.2",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-moment-shim": "^3.8.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-cli-yuidoc": "^0.9.1",
    "ember-data": "^5.8.2",
    "ember-disable-prototype-extensions": "^1.1.3",
    "ember-exam": "^10.1.0",
    "ember-export-application-global": "^2.0.1",
    "ember-load-initializers": "^3.0.1",
    "ember-maybe-import-regenerator": "^1.0.0",
    "ember-moment": "^11.1.0",
    "ember-page-title": "^9.0.3",
    "ember-prism": "^1.0.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^7.9.3",
    "ember-try": "^4.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^13.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "gh-pages": "^6.3.0",
    "lint-staged": ">=16",
    "loader.js": "^4.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "release-it": "^15.11.0",
    "release-it-lerna-changelog": "^5.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "yuidoc-ember-theme": "^2.0.1"
  },
  "peerDependencies": {
    "dayjs": "^1.11.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config",
    "demoURL": "https://summit-electric-supply.github.io/ember-validators"
  },
  "release-it": {
    "hooks": {
      "after:release": [
        "npm run deploy"
      ]
    }
  },
  "engines": {
    "node": "12.* || 14.* || >= 16"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix"
  },
  "exports": {
    ".": "./addon/index.js",
    "./validators/*": "./addon/validators/*.js",
    "./*": "./addon/*"
  }
}
